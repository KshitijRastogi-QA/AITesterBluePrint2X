GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Qdrant: file-store mode (no Docker needed)
QDRANT_PATH=./qdrant_data
# Switch to HTTP mode if you need concurrent reads+writes:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBED_DEVICE=cpu          # mps for Apple Silicon, cuda for NVIDIA

# Source paths (relative to project root)
SELENIUM_REPO_DIR=./data/selenium_repo
PLAYWRIGHT_REPO_DIR=./data/playwright_repo
TESTCASES_CSV=./data/csv/testcases_vwo_100.csv
PDFS_DIR=./data/pdf
JIRA_MD_DIR=./data/md

# Retrieval knobs
TOP_K_PER_COLLECTION=12
RERANK_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
HISTORY_TURNS=4
